# Copy this file to .env on the server.
# Never commit your real .env file.

PORT=4173
SCHEDULE_ENABLED=1
SCHEDULE_TIME=02:00
SCHEDULE_TZ_OFFSET_MINUTES=330

# MySQL Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=job_search_portal

# JWT Secret (change this to a secure random string)
JWT_SECRET=your-very-secret-key-change-this-in-production

# Apify Configuration (centralized for all users)
APIFY_API_KEY=
APIFY_TASK_ID=

# Optional AI API keys. Leave blank if you do not have them yet.
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
RAPIDAPI_JSEARCH_KEY=

# Fully free local AI. Install Ollama on the same server.
OLLAMA_ENABLED=1
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:0.5b
OLLAMA_MAX_JOBS=25

# Optional Apify setup. Not required for the free-provider automation.
DEFAULT_APIFY_MODE=task
APIFY_TASK_ID=
APIFY_ACTOR_ID=
APIFY_DATASET_ID=

DEFAULT_MAX_ITEMS=75
DEFAULT_LOCATION=Remote, India, UAE
DEFAULT_KEYWORDS=AI voice engineer,VoIP engineer,SIP engineer,telecom infrastructure,founding engineer,CPaaS platform engineer,Asterisk engineer,WebRTC engineer,Linux telephony engineer,cloud telephony architect
MIN_SCORE=38

REMOTIVE_ENABLED=1
ARBEITNOW_ENABLED=1
STORE_MAX_JOBS=500
