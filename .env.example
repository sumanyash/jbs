# Copy this file to .env on the server.
# Never commit your real .env file.

PORT=4173
APIFY_API_KEY=apify_api_your_key_here

# Recommended: create an Apify task first, then paste its task ID here.
DEFAULT_APIFY_MODE=task
APIFY_TASK_ID=username~your-job-scraper-task

# Optional alternatives:
APIFY_ACTOR_ID=
APIFY_DATASET_ID=

DEFAULT_MAX_ITEMS=75
DEFAULT_LOCATION=Remote, India, UAE
DEFAULT_KEYWORDS=AI voice engineer,VoIP engineer,SIP engineer,telecom infrastructure,founding engineer,CPaaS platform engineer,Asterisk engineer,WebRTC engineer,Linux telephony engineer,cloud telephony architect
